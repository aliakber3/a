<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>If Else Assignment</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 40px;
            background-color: #f4f4f9;
            color: #333;
        }
        h1 {
            color: #2c3e50;
        }
        p {
            font-size: 1.1em;
        }
        .instruction {
            background-color: #e8f4fd;
            padding: 15px;
            border-left: 5px solid #3498db;
            border-radius: 4px;
        }
    </style>
</head>
<body>

    <h1>JavaScript If/Else Assignment</h1>
    <p class="instruction">
        <strong>Note:</strong> All answers are executed in the JavaScript engine. 
        Right-click on this page, select <strong>Inspect</strong>, and go to the <strong>Console</strong> tab to see the outputs!
    </p>

    <script>
        // ============================================
        // JAVASCRIPT ASSIGNMENT — if / else / else if
        // ============================================
        // Name: Student
        // Date: 12 June
        // ============================================


        // Q1 — Even or Odd
        console.log("--- Q1 ---");
        let number = 7;

        if (number % 2 === 0) {
            console.log(number + " is Even");
        } else {
            console.log(number + " is Odd");
        }


        // Q2 — Positive, Negative or Zero
        console.log("--- Q2 ---");
        let number2 = -5;

        if (number2 > 0) {
            console.log("Positive number");
        } else if (number2 < 0) {
            console.log("Negative number");
        } else {
            console.log("Zero");
        }


        // Q3 — Biggest of Two Numbers
        console.log("--- Q3 ---");
        let a = 15;
        let b = 20;

        if (a > b) {
            console.log("a is bigger");
        } else if (b > a) {
            console.log("b is bigger");
        } else {
            console.log("Both are equal");
        }


        // Q4 — Pass or Fail
        console.log("--- Q4 ---");
        let marks = 35;

        if (marks >= 40) {
            console.log("Passed");
        } else {
            console.log("Failed");
        }


        // Q5 — Child, Teen or Adult
        console.log("--- Q5 ---");
        let age = 14;

        if (age >= 0 && age <= 12) {
            console.log("Child");
        } else if (age >= 13 && age <= 17) {
            console.log("Teenager");
        } else if (age >= 18) {
            console.log("Adult");
        } else {
            console.log("Invalid Age");
        }


        // Q6 — Hottest City
        console.log("--- Q6 ---");
        let karachi = 38;
        let lahore  = 42;

        if (karachi > lahore) {
            console.log("Karachi is hotter");
        } else if (lahore > karachi) {
            console.log("Lahore is hotter");
        } else {
            console.log("Both cities have the same temperature");
        }


        // Q7 — Discount Check
        console.log("--- Q7 ---");
        let bill = 750;

        if (bill >= 1000) {
            console.log("10% discount applied");
        } else if (bill >= 500) {
            console.log("5% discount applied");
        } else {
            console.log("No discount");
        }


        // Q8 — Battery Warning
        console.log("--- Q8 ---");
        let battery = 18;

        if (battery >= 50 && battery <= 100) {
            console.log("Battery Good");
        } else if (battery >= 20 && battery < 50) {
            console.log("Battery Low, plug in soon");
        } else if (battery < 20 && battery >= 0) {
            console.log("Critical! Plug in now!");
        } else {
            console.log("Invalid battery percentage");
        }


        // Q9 — Weekday or Weekend
        console.log("--- Q9 ---");
        let day = 6;

        if (day >= 1 && day <= 5) {
            console.log("Weekday, go to school");
        } else if (day === 6 || day === 7) {
            console.log("Weekend, enjoy!");
        } else {
            console.log("Invalid day");
        }


        // Q10 — Speed Fine Calculator
        console.log("--- Q10 ---");
        let speed = 95;

        if (speed < 60) {
            console.log("Safe driving");
        } else if (speed >= 60 && speed <= 80) {
            console.log("Slight overspeed, warning");
        } else if (speed >= 81 && speed <= 120) {
            console.log("Fine: Rs 500");
        } else if (speed > 120) {
            console.log("Heavy fine: Rs 2000 + license cancelled");
        }


        // Q11 — Electricity Bill
        console.log("--- Q11 ---");
        let units = 150;
        let totalBill = 0;

        // Note: Electricity calculation works step-by-step per tier
        if (units <= 100) {
            totalBill = units * 5;
        } else if (units <= 300) {
            totalBill = (100 * 5) + ((units - 100) * 10);
        } else {
            totalBill = (100 * 5) + (200 * 10) + ((units - 300) * 20);
        }
        console.log("Total bill: Rs " + totalBill);


        // Q12 — Login Check
        console.log("--- Q12 ---");
        let username = "student";
        let password = "abc123";

        if (username !== "student") {
            console.log("Username not found");
        } else if (password !== "abc123") {
            console.log("Wrong password");
        } else {
            console.log("Login successful!");
        }


        // Q13 — Triangle Type
        console.log("--- Q13 ---");
        let side1 = 5;
        let side2 = 5;
        let side3 = 8;

        if (side1 === side2 && side2 === side3) {
            console.log("Equilateral triangle");
        } else if (side1 === side2 || side2 === side3 || side1 === side3) {
            console.log("Isosceles triangle");
        } else {
            console.log("Scalene triangle");
        }


        // Q14 — Shopping Cart
        console.log("--- Q14 ---");
        let items    = 12;
        let isMember = false;

        if (items >= 10 && isMember === true) {
            console.log("20% discount");
        } else if (items >= 10 && isMember === false) {
            console.log("10% discount");
        } else if (items < 10 && isMember === true) {
            console.log("5% discount");
        } else {
            console.log("No discount");
        }
    </script>
</body>
</html>
